# ── Local development ─────────────────────────────────────────────
# Copy to .env.local and fill in values. Never commit .env.local.

# Convex (from `bunx convex dev` or Convex dashboard)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.eu-west-1.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.eu-west-1.convex.site
CONVEX_DEPLOYMENT=dev:your-deployment-name

# Cloudinary (https://console.cloudinary.com)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Gmail SMTP (App Password — https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your@gmail.com
CONTACT_TO=your@gmail.com

# Admin one-time setup (long random string — set on Vercel AND Convex prod)
ADMIN_SETUP_KEY=

# Public site URL (production: https://malitos.dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Vercel production only (do NOT add to .env.local) ─────────────
# Generate in Convex Dashboard → Settings → Deploy Key
# CONVEX_DEPLOY_KEY=
