# =============================================================================
# Devmalitos — environment variables
# Copy to .env.local for local dev. Use the Vercel section when deploying.
# Never commit .env.local.
# =============================================================================


# ── LOCAL DEVELOPMENT ONLY (.env.local) ───────────────────────────────────────
# Run: bunx convex dev  (fills Convex vars automatically)

NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_TO=

ADMIN_SETUP_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# One-time Convex CMS seed (scripts/seed-convex.mjs)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=


# ── VERCEL PRODUCTION ─────────────────────────────────────────────────────────
# Do NOT import .env.local directly — it has dev-only vars.
#
# Run:  bun run prepare:vercel
# Import .env.vercel.import in Vercel → Settings → Environment Variables → Production
#
# Also set ADMIN_SETUP_KEY in Convex Dashboard → Production → Environment Variables
