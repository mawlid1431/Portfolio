# =============================================================================
# Devmalitos — environment variables
# Copy to .env.local for local dev. Use the Vercel section when deploying.
# Never commit .env.local.
# =============================================================================


# ── LOCAL DEVELOPMENT ONLY (.env.local) ───────────────────────────────────────
# Run: bunx convex dev  (fills Convex vars automatically)

NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_TO=

ADMIN_SETUP_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ── VERCEL PRODUCTION (import these to Vercel → Environment Variables) ──────
# Scope: Production (and Preview if you want preview deploys)
#
# DO NOT import on Vercel:
#   CONVEX_DEPLOYMENT          → local dev only
#   NEXT_PUBLIC_CONVEX_SITE_URL → not used by the app
#   CLOUDINARY_URL             → optional shorthand, not required
#
# Convex on Vercel — pick ONE:
#   A) CONVEX_DEPLOY_KEY        → auto-deploys Convex during build (best)
#   B) NEXT_PUBLIC_CONVEX_URL   → use prod URL if you deploy Convex locally
#      Production URL: https://mellow-camel-842.eu-west-1.convex.cloud
#
# ALSO set in Convex Dashboard → Production → Settings → Environment Variables:
#   ADMIN_SETUP_KEY            → must match Vercel value exactly

# CONVEX_DEPLOY_KEY=            ← option A: Convex Production → Settings → General
# NEXT_PUBLIC_CONVEX_URL=https://mellow-camel-842.eu-west-1.convex.cloud  ← option B

# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# CONTACT_TO=

# ADMIN_SETUP_KEY=              ← strong random string (not devmalitos-setup)
# NEXT_PUBLIC_SITE_URL=https://malitos.dev
